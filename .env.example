# ── Flask ──────────────────────────────────────────
SECRET_KEY=a_very_long_random_secret_key_here

# ── Admin اولیه (فقط برای اولین راه‌اندازی) ──────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# ── Instagram OAuth (Business Login) ───────────────
META_APP_ID=your_instagram_app_id
META_APP_SECRET=your_instagram_app_secret
OAUTH_REDIRECT_URI=http://127.0.0.1:5000/auth/instagram/callback
OAUTH_SCOPES=instagram_business_basic,instagram_business_manage_messages,instagram_business_manage_comments

# ── Webhook (اختیاری — یا از پنل تنظیمات) ────────
VERIFY_TOKEN=mysecret123

# ── Media & Deploy ─────────────────────────────────
PUBLIC_BASE_URL=http://127.0.0.1:5000
PORT=5000

# ── PostgreSQL (Render) ────────────────────────────
# DATABASE_URL=postgresql://...
